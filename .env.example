# ============================================================
#  Nanei API — Variables d'environnement
#  Copier ce fichier en .env et remplir toutes les valeurs.
#  NE JAMAIS committer le fichier .env.
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
BACKEND_URL=http://localhost:3000

# ── Logs ─────────────────────────────────────────────────────
# Chemin absolu du dossier de logs (crée automatiquement si absent en production)
# Défaut : <racine_projet>/logs
LOG_DIR=/var/www/nanei-api/logs
LOG_LEVEL=info

# ── Base de données PostgreSQL ────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nanei
DB_USER=naneiuser
DB_PASSWORD=CHANGE_MOI_MOT_DE_PASSE_FORT

# SSL PostgreSQL : laisser vide si PostgreSQL est sur le même serveur (loopback)
# Sinon : contenu du certificat CA en base64
DB_SSL_CA=

# ── JWT ──────────────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_MOI_SECRET_JWT_64_CHARS_MIN
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_MOI_REFRESH_SECRET_DIFFERENT

# ── CORS ─────────────────────────────────────────────────────
# URL de l'app mobile / front — JAMAIS * en production
# Plusieurs origines : CORS_ORIGIN=https://app.nanei.com,https://admin.nanei.com
CORS_ORIGIN=https://YOUR_DOMAIN

# URL du frontend (utilisée pour les liens dans les emails, etc.)
FRONTEND_URL=https://YOUR_DOMAIN

# App deep link pour redirects post-paiement
APP_DEEP_LINK=nanei

# ── Admin par défaut ──────────────────────────────────────────
# Créé au 1er démarrage si absent. Obligatoire de changer ces valeurs.
ADMIN_EMAIL=admin@votre-domaine.com
ADMIN_PASSWORD=ChangeMe_MotDePasseForte123!
ADMIN_NOM=Admin
ADMIN_PRENOM=Nanei
ADMIN_ADRESSE=Dakar, Senegal

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Nanei <noreply@votre-domaine.com>

# ── SMTP (alternative à Resend) ──────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# ── Cloudinary (images & documents) ───────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Firebase FCM (notifications push) ─────────────────────────
# Contenu JSON du fichier serviceAccount Firebase sur une seule ligne
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Wave Money ────────────────────────────────────────────────
WAVE_API_KEY=
WAVE_MERCHANT_ID=
WAVE_WEBHOOK_SECRET=CHANGE_MOI_WAVE_WEBHOOK_SECRET

# ── Orange Money ──────────────────────────────────────────────
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_WEBHOOK_SECRET=CHANGE_MOI_ORANGE_WEBHOOK_SECRET

# ── Twilio (SMS) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── PM2 ──────────────────────────────────────────────────────
# Nombre d'instances PM2 : "max" = 1 par cœur CPU | 1 = single process
PM2_INSTANCES=max
